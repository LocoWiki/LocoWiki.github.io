  "pageStandards": {
    "frames": {
      "page": {
        "description": "Structured internal landing pages rendered from JSON blocks",
        "requiredBlocks": ["hero", "sections"],
        "optionalBlocks": ["metrics", "callout", "cta"]
      },
      "docs": {
        "description": "Long-form reading pages rendered from Markdown with TOC and pager",
        "requiredBlocks": ["meta", "content"],
        "optionalBlocks": ["toc", "pager"]
      }
    },
    "pages": {
      "index.html": { "frame": "page", "source": "json" },
