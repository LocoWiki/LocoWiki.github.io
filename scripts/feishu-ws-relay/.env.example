# Feishu app credentials (Open Platform)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated Feishu event types that your app subscribed in console.
# Example: im.message.receive_v1,contact.user.deleted_v3
FEISHU_EVENT_TYPES=im.message.receive_v1

# GitHub repository_dispatch target
GITHUB_OWNER=Lain-Ego0
GITHUB_REPO=LocoWiki.github.io
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_EVENT_TYPE=feishu_wiki_sync

# Optional fields
FEISHU_SPACE_URL=https://wcn9j5638vrr.feishu.cn/wiki/space/7570988375279517715?ccm_open_type=lark_wiki_spaceLink&open_tab_from=wiki_home
FEISHU_DOMAIN=https://open.feishu.cn
LOG_LEVEL=debug
